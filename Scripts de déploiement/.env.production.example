# Configuration de Production pour EC2
# Copiez ce fichier en .env et remplissez les valeurs

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=iusjc_schedule
DB_USERNAME=iusjc_user
# IMPORTANT: Changez ce mot de passe!
DB_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_FORT_123

# ==========================================
# JWT CONFIGURATION
# ==========================================
# Générez une clé secrète forte avec: openssl rand -base64 64
JWT_SECRET=CHANGEZ_MOI_CLE_SECRETE_TRES_LONGUE_ET_ALEATOIRE
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ==========================================
# EMAIL CONFIGURATION (Gmail)
# ==========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre-email@gmail.com
# Utilisez un mot de passe d'application Gmail
# Guide: https://support.google.com/accounts/answer/185833
MAIL_PASSWORD=votre_mot_de_passe_application_gmail
MAIL_FROM=votre-email@gmail.com

# ==========================================
# CLOUDINARY CONFIGURATION
# ==========================================
# Obtenez vos credentials sur: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
# L'URL publique de votre application (avec votre domaine ou IP EC2)
# Exemple: https://schedule.iusjc.cm ou http://54.123.45.67
PUBLIC_URL=http://VOTRE_IP_OU_DOMAINE

# ==========================================
# SECURITY
# ==========================================
# Activez HTTPS en production
FORCE_HTTPS=false

# ==========================================
# MONITORING (Optionnel)
# ==========================================
# Activez les métriques pour le monitoring
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
